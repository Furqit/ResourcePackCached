{
  "schemaVersion": 1,
  "id": "${id}",
  "version": "${version}",
  "name": "${name}",
  "description": "Keeps server resource packs loaded, so they don't need to be reloaded when you rejoin.",
  "authors": [
    "Furq"
  ],
  "contact": {
    "homepage": "https://modrinth.com/mod/resourcepackcached",
    "sources": "https://github.com/Furqit/ResourcePackCached",
    "issues": "https://github.com/Furq07/ResourcePackCached/issues"
  },
  "license": "GPL-3.0",
  "icon": "assets/rpc/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "dev.furq.resourcepackcached.ResourcePackCached"
    ]
  },
  "mixins": [
    "rpc.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.17",
    "minecraft": "${minecraft}"
  },
  "accessWidener": "rpc.ct"
}